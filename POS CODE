  if(!from || !to) { showToast('Define valid parameters boundary first'); return; }
  
  const sales = DB.sales.filter(s=>dateInRange(s.date, from, to));
  const expenses = DB.expenses.filter(e=>dateInRange(e.date, from, to));
  
  const totalInwardGross = sales.reduce((a,s)=>a+s.total,0);
  const totalOutwardExp = expenses.reduce((a,e)=>a+e.amount,0);
  const netOperatingSpread = totalInwardGross - totalOutwardExp;
  
  document.getElementById('reportResult').innerHTML = `
    <div class="grid grid-3">
      <div class="stat"><div class="num">৳ ${money(totalInwardGross)}</div><div class="lbl">Gross Calculated Sales Inflow</div></div>
      <div class="stat"><div class="num">৳ ${money(totalOutwardExp)}</div><div class="lbl">Total Tracked Overhead Outflows</div></div>
      <div class="stat"><div class="num" style="color:${netOperatingSpread >= 0 ? 'var(--ok)':'var(--bad)'}">৳ ${money(netOperatingSpread)}</div><div class="lbl">Net Cash Operations Yield</div></div>
    </div>`;
}

