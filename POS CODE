function collectDuePrompt(saleId) {
  const s = DB.sales.find(x=>x.id===saleId); if(!s) return;
  const html = `
    <p>Clearing Balance for Invoice <b>${s.invoiceNo}</b></p>
    <div class="field"><label>Collection Amount (৳)</label><input id="collAmt" type="number" value="${s.dueAmount}"></div>
    <div class="field"><label>Method</label><select id="collMethod"><option value="cash">Cash</option><option value="bank">Bank Wire</option><option value="bkash">bKash MFS</option></select></div>
    <div class="field"><label>Reference Token</label><input id="collRef" placeholder="TxID / Note"></div>`;
  openModal("Receive Due Balance", html, ()=>{
    const amt = Number(document.getElementById('collAmt').value)||0;
    if(amt <= 0) return;
    s.payments = s.payments || [];
    s.payments.push({date:nowISO(), amount:amt, method:document.getElementById('collMethod').value, ref:document.getElementById('collRef').value.trim()});
    s.paidTotal += amt;
    s.dueAmount = Math.max(0, s.dueAmount - amt);
    s.status = s.dueAmount <= 0 ? 'paid' : 'partial';
    
    // adjust client accounts
    if(s.dealerId){
      const d = DB.dealers.find(x=>x.id===s.dealerId);
      if(d) d.dueBalance = Math.max(0, (d.dueBalance||0) - amt);
    } else {
      const c = findCustomerByPhone(s.customerPhone);
      if(c) c.dueBalance = Math.max(0, (c.dueBalance||0) - amt);
    }
    saveCore(); showToast("Payment collection posted successfully"); goTo('due');
  });
}

