<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monzu Plumbing Works — POS</title>
<style>
:root{
  --steel-900:#12202b; --steel-800:#1b2f3d; --steel-700:#25404f;
  --steel-100:#eef3f4; --paper:#f7f5f1; --copper:#b56a35; --copper-dark:#8f4f24;
  --copper-light:#e8c9a3; --ink:#1c2427; --line:#d8d2c6;
  --ok:#3f7a52; --ok-bg:#e6f0e8; --bad:#a4402f; --bad-bg:#f6e6e2; --warn:#a67c1c; --warn-bg:#f5edda;
  --mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}
*{box-sizing:border-box;}
body{margin:0;font-family:var(--sans);background:var(--paper);color:var(--ink);}
::selection{background:var(--copper-light);}
a{color:inherit;}
button{font-family:inherit;cursor:pointer;}
input,select,textarea{font-family:inherit;}

/* ---------- login ---------- */
#loginScreen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:
  radial-gradient(circle at 20% 20%, #1e3646 0%, var(--steel-900) 60%);}
.login-card{background:var(--paper);width:380px;max-width:92vw;border-radius:4px;padding:34px 30px;
  box-shadow:0 20px 60px rgba(0,0,0,.35);border-top:4px solid var(--copper);}
.brand{display:flex;align-items:center;gap:10px;margin-bottom:6px;}
.brand-mark{width:34px;height:34px;flex:none;}
.brand h1{font-size:17px;margin:0;letter-spacing:.3px;}
.brand small{display:block;color:#7a746a;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin-top:2px;}
.field{margin-top:16px;}
.field label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:#7a746a;margin-bottom:5px;}
.field input,.field select,.field textarea{width:100%;padding:10px 11px;border:1px solid var(--line);border-radius:3px;background:#fff;font-size:14px;}
.field input:focus,.field select:focus,.field textarea:focus{outline:2px solid var(--copper-light);border-color:var(--copper);}
.btn{display:inline-block;border:none;border-radius:3px;padding:10px 16px;font-size:13.5px;font-weight:600;letter-spacing:.2px;}
.btn-copper{background:var(--copper);color:#fff;}
.btn-copper:hover{background:var(--copper-dark);}
.btn-ghost{background:transparent;color:var(--steel-800);border:1px solid var(--line);}
.btn-ghost:hover{background:var(--steel-100);}
.btn-danger{background:var(--bad);color:#fff;}
.btn-danger:hover{background:#8a3324;}
.btn-sm{padding:6px 10px;font-size:12px;}
.btn-block{width:100%;text-align:center;}
.login-actions{margin-top:20px;display:flex;flex-direction:column;gap:8px;}
.linklike{background:none;border:none;color:var(--copper-dark);font-size:12.5px;text-decoration:underline;padding:4px 0;text-align:left;}
#loginError{color:var(--bad);font-size:12.5px;margin-top:10px;min-height:14px;}

/* ---------- app shell ---------- */
#app{display:none;min-height:100vh;}
.shell{display:flex;min-height:100vh;}
.sidebar{width:230px;flex:none;background:var(--steel-900);color:#dbe4e8;padding:18px 0;position:sticky;top:0;height:100vh;overflow-y:auto;}
.sidebar .brand{padding:0 18px 16px;border-bottom:1px solid #24404f;}
.sidebar .brand h1{color:#fff;font-size:15px;}
.sidebar .brand small{color:#8fa3ab;}
.nav-group{margin-top:14px;}
.nav-group-title{font-size:10px;text-transform:uppercase;letter-spacing:1.2px;color:#5e7681;padding:6px 18px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 18px;font-size:13.5px;color:#c9d6da;cursor:pointer;border-left:3px solid transparent;}
.nav-item:hover{background:#1c313d;}
.nav-item.active{background:#1c313d;border-left-color:var(--copper);color:#fff;font-weight:600;}
.nav-icon{width:16px;text-align:center;font-family:var(--mono);opacity:.85;}
.main{flex:1;min-width:0;}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;background:#fff;border-bottom:1px solid var(--line);position:sticky;top:0;z-index:5;}
.topbar h2{margin:0;font-size:17px;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.chip{font-size:11.5px;background:var(--steel-100);border-radius:20px;padding:5px 12px;color:var(--steel-800);}
.content{padding:22px 24px 60px;max-width:1200px;}

/* ---------- generic ---------- */
.card{background:#fff;border:1px solid var(--line);border-radius:5px;padding:18px 20px;margin-bottom:18px;}
.card h3{margin:0 0 14px;font-size:14.5px;letter-spacing:.2px;}
.grid{display:grid;gap:14px;}
.grid-2{grid-template-columns:1fr 1fr;}
.grid-3{grid-template-columns:1fr 1fr 1fr;}
.grid-4{grid-template-columns:repeat(4,1fr);}
@media(max-width:900px){.grid-2,.grid-3,.grid-4{grid-template-columns:1fr;} .sidebar{position:fixed;left:-230px;z-index:20;transition:left .2s;} .sidebar.open{left:0;} .shell{display:block;}}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{text-align:left;font-size:10.5px;text-transform:uppercase;letter-spacing:.6px;color:#7a746a;padding:8px 10px;border-bottom:2px solid var(--line);}
td{padding:9px 10px;border-bottom:1px solid #ece7dd;vertical-align:top;}
tr:hover td{background:#faf9f6;}
.mono{font-family:var(--mono);}
.right{text-align:right;}
.center{text-align:center;}
.muted{color:#8a8478;}
.small{font-size:12px;}
.badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;}
.badge-ok{background:var(--ok-bg);color:var(--ok);}
.badge-bad{background:var(--bad-bg);color:var(--bad);}
.badge-warn{background:var(--warn-bg);color:var(--warn);}
.stat{background:#fff;border:1px solid var(--line);border-radius:5px;padding:16px 18px;}
.stat .num{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--steel-900);}
.stat .lbl{font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#8a8478;margin-top:4px;}
.divider-pipe{height:8px;background-repeat:repeat-x;background-size:14px 8px;
  background-image:repeating-linear-gradient(90deg,var(--copper-light) 0 6px, transparent 6px 14px);
  margin:16px 0;border-radius:2px;}
.hr{border:none;border-top:1px solid var(--line);margin:16px 0;}
.pill-row{display:flex;gap:8px;flex-wrap:wrap;}
.toggle-row{display:flex;border:1px solid var(--line);border-radius:20px;overflow:hidden;width:fit-content;}
.toggle-row button{border:none;background:#fff;padding:6px 14px;font-size:12.5px;}
.toggle-row button.active{background:var(--steel-900);color:#fff;}
.modal-bg{position:fixed;inset:0;background:rgba(15,25,30,.5);display:flex;align-items:flex-start;justify-content:center;padding:40px 16px;overflow:auto;z-index:50;}
.modal{background:#fff;border-radius:6px;width:520px;max-width:100%;padding:22px 24px;border-top:4px solid var(--copper);}
.modal h3{margin-top:0;}
.close-x{float:right;background:none;border:none;font-size:18px;color:#8a8478;}
.items-table input, .items-table select{padding:6px 7px;font-size:12.5px;}
.empty{padding:30px;text-align:center;color:#8a8478;font-size:13px;border:1px dashed var(--line);border-radius:6px;}
.tag{background:var(--steel-100);border-radius:3px;padding:2px 7px;font-size:11px;margin-right:4px;}
.invoice-box{border:1px solid var(--line);padding:20px;border-radius:6px;background:#fff;}
.invoice-box .ihead{display:flex;justify-content:space-between;align-items:flex-start;}
.invoice-box .ihead img{max-height:50px;}
.searchbar{display:flex;gap:8px;margin-bottom:14px;}
.searchbar input{flex:1;}
#toast{position:fixed;bottom:20px;right:20px;background:var(--steel-900);color:#fff;padding:11px 18px;border-radius:5px;font-size:13px;z-index:100;box-shadow:0 8px 24px rgba(0,0,0,.3);display:none;}
.hamburger{display:none;background:none;border:none;font-size:20px;}
@media(max-width:900px){.hamburger{display:block;}}
label.inline{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:normal;text-transform:none;letter-spacing:0;color:var(--ink);}

@media print {
  body * { visibility: hidden; }
  #invoicePrintArea, #invoicePrintArea * { visibility: visible; }
  #invoicePrintArea { position: absolute; left: 0; top: 0; width: 100%; border: none; padding: 0; }
  .modal-bg { background: transparent; position: absolute; }
  .modal { border: none; box-shadow: none; padding: 0; width: 100%; max-width: 100%; }
  .pill-row, .close-x { display: none !important; }
}
</style>
</head>
<body>

<div id="loginScreen">
  <div class="login-card">
    <div class="brand">
      <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="19" fill="#12202b"/><path d="M12 20h6v-6h4v6h6v4h-6v6h-4v-6h-6z" fill="#b56a35"/></svg>
      <div><h1>Monzu Plumbing Works</h1><small>Point of Sale</small></div>
    </div>
    <div id="loginBody"></div>
  </div>
</div>

<div id="app">
  <div class="shell">
    <div class="sidebar" id="sidebar"></div>
    <div class="main">
      <div class="topbar">
        <div style="display:flex;align-items:center;gap:10px;">
          <button class="hamburger" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
          <h2 id="pageTitle"></h2>
        </div>
        <div class="topbar-right">
          <div class="toggle-row" id="langToggle"></div>
          <span class="chip" id="userChip"></span>
          <button class="btn btn-ghost btn-sm" onclick="logout()" id="logoutBtn"></button>
        </div>
      </div>
      <div class="content" id="content"></div>
    </div>
  </div>
</div>

<div id="toast"></div>

<script>
/* ============================= ENVIRONMENT STORAGE FALLBACK ============================= */
if (!window.storage) {
  window.storage = {
    get: function(key, isJson) {
      return new Promise((resolve) => {
        let val = localStorage.getItem(key);
        resolve(val ? { value: val } : null);
      });
    },
    set: function(key, val, isJson) {
      return new Promise((resolve) => {
        localStorage.setItem(key, val);
        resolve(true);
      });
    }
  };
}

/* ============================= I18N ============================= */
const I18N = {
en:{
  dashboard:"Dashboard", quicksell:"Quick Sell", invoices:"Invoices", products:"Products & Stock",
  purchases:"Purchase Stock", due:"Due Management", warranty:"Warranty Claims", premium:"Premium Care",
  dealers:"Dealership", staff:"Staff Management", expenses:"Expenses", extraIncome:"Extra Income",
  repair:"Repair Service", reports:"Accounting & Reports", notes:"Quick Notes", sms:"SMS Center",
  settings:"Invoice & Company Settings", admins:"Admin Management", customerLookup:"Customer Lookup",
  logout:"Log out", username:"Username", password:"Password", login:"Log in", forgot:"Forgot username or password?",
  recoveryCode:"Recovery code", back:"Back", save:"Save", cancel:"Cancel", add:"Add", edit:"Edit", delete:"Delete",
  search:"Search", name:"Name", phone:"Phone", address:"Address", total:"Total", discount:"Discount",
  paid:"Paid", dueAmt:"Due", date:"Date", action:"Action", status:"Status", none:"None"
},
bn:{
  dashboard:"ড্যাশবোর্ড", quicksell:"দ্রুত বিক্রয়", invoices:"ইনভয়েস", products:"পণ্য ও স্টক",
  purchases:"স্টক ক্রয়", due:"বকেয়া ব্যবস্থাপনা", warranty:"ওয়ারেন্টি দাবি", premium:"প্রিমিয়াম কেয়ার",
  dealers:"ডিলারশিপ", staff:"কর্মচারী ব্যবস্থাপনা", expenses:"খরচ", extraIncome:"অতিরিক্ত আয়",
  repair:"মেরামত সেবা", reports:"হিসাব ও রিপোর্ট", notes:"দ্রুত নোট", sms:"এসএমএস সেন্টার",
  settings:"ইনভয়েস ও কোম্পানি সেটিংস", admins:"অ্যাডমিন ব্যবস্থাপনা", customerLookup:"কাস্টমার খোঁজ",
  logout:"লগ আউট", username:"ইউজারনেম", password:"পাসওয়ার্ড", login:"লগইন", forgot:"ইউজারনেম বা পাসওয়ার্ড ভুলে গেছেন?",
  recoveryCode:"রিকভারি কোড", back:"ফিরে যান", save:"সংরক্ষণ", cancel:"বাতিল", add:"যোগ করুন", edit:"সম্পাদনা",
  delete:"মুছুন", search:"খুঁজুন", name:"নাম", phone:"ফোন", address:"ঠিকানা", total:"মোট", discount:"ছাড়",
  paid:"পরিশোধিত", dueAmt:"বকেয়া", date:"তারিখ", action:"অ্যাকশন", status:"অবস্থা", none:"কোনটি না"
}};
let LANG = 'en';
function t(k){ return (I18N[LANG] && I18N[LANG][k]) || (I18N.en[k]) || k; }

/* ============================= STORAGE ============================= */
const CORE_KEY = 'pos_core_v1';
const SETTINGS_KEY = 'pos_settings_v1';

function defaultCore(){
  return {
    products:[], sales:[], purchases:[], customers:[], dealers:[],
    staff:[], attendance:[], advances:[], expenses:[], extraIncome:[],
    repairs:[], notes:[], warrantyClaims:[], premiumCare:[], smsLogs:[],
    seq:{invoice:1000, repair:500}
  };
}
function defaultSettings(){
  return {
    company:{ name:"Monzu Plumbing Works", address:"Chittagong Port, Chattogram, Bangladesh", phoneNum:"018XXXXXXXX", logo:"", invoiceTitle:"SALES INVOICE", footerNote:"Thank you for your business." },
    admins:[{id:'1', username:'admin', password:'1234', name:'Super Admin', role:'Super Admin', isSuper:true}],
    repairCategories:["Coil Winding","Bearing","Water Seal","Impeller","Motor Set","Coil Set"],
    smsTemplates:{
      dueReminder:"Dear {name}, you have a due of Tk {amount} against invoice {invoice}. Please clear it soon. - {company}",
      thankYou:"Dear {name}, thank you for your purchase (Invoice {invoice}). - {company}"
    }
  };
}
let DB = defaultCore();
let SETTINGS = defaultSettings();
let CURRENT_ADMIN = null;

async function loadAll(){
  try{
    const c = await window.storage.get(CORE_KEY, true);
    if(c && c.value) DB = Object.assign(defaultCore(), JSON.parse(c.value));
  }catch(e){ }
  try{
    const s = await window.storage.get(SETTINGS_KEY, true);
    if(s && s.value) SETTINGS = Object.assign(defaultSettings(), JSON.parse(s.value));
  }catch(e){ }
  try{
    const l = await window.storage.get('pos_lang_pref', false);
    if(l && l.value) LANG = l.value;
  }catch(e){}
}
async function saveCore(){
  try{ await window.storage.set(CORE_KEY, JSON.stringify(DB), true); }
  catch(e){ showToast('Storage error — changes may not be saved.'); }
}
async function saveSettings(){
  try{ await window.storage.set(SETTINGS_KEY, JSON.stringify(SETTINGS), true); }
  catch(e){ showToast('Storage error — changes may not be saved.'); }
}
async function saveLangPref(){
  try{ await window.storage.set('pos_lang_pref', LANG, false); }catch(e){}
}

/* ============================= HELPERS ============================= */
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,7); }
function money(n){ n = Number(n)||0; return n.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:2}); }
function todayStr(){ return new Date().toISOString().slice(0,10); }
function nowISO(){ return new Date().toISOString(); }
function esc(s){ return (s===undefined||s===null)?'':String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function showToast(msg){
  const el = document.getElementById('toast');
  el.textContent = msg; el.style.display='block';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=>{el.style.display='none';},2600);
}
function genInvoiceNo(){ DB.seq.invoice++; return 'INV-'+DB.seq.invoice; }
function genRepairCode(){ DB.seq.repair++; return 'REP-'+DB.seq.repair; }
function findProduct(id){ return DB.products.find(p=>p.id===id); }
function findCustomerByPhone(phone){ return DB.customers.find(c=>c.phone===phone); }
function upsertCustomer(name,phone,address){
  if(!phone) return null;
  let c = findCustomerByPhone(phone);
  if(!c){ c = {id:uid(), name:name||'', phone, address:address||'', dueBalance:0}; DB.customers.push(c); }
  else { if(name) c.name = name; if(address) c.address = address; }
  return c;
}
function warrantyLabel(p){
  if(!p || !p.warrantyValue) return t('none');
  const unitMap = {days:{en:'day(s)',bn:'দিন'}, months:{en:'month(s)',bn:'মাস'}, years:{en:'year(s)',bn:'বছর'}};
  const u = unitMap[p.warrantyUnit] || unitMap.months;
  return p.warrantyValue + ' ' + (u[LANG]||u.en);
}
function warrantyExpiry(saleDate, p){
  if(!p || !p.warrantyValue) return null;
  const d = new Date(saleDate);
  if(p.warrantyUnit==='days') d.setDate(d.getDate()+Number(p.warrantyValue));
  else if(p.warrantyUnit==='years') d.setFullYear(d.getFullYear()+Number(p.warrantyValue));
  else d.setMonth(d.getMonth()+Number(p.warrantyValue));
  return d;
}
function dateInRange(dateStr, from, to){
  const d = new Date(dateStr.slice(0,10));
  if(from && d < new Date(from)) return false;
  if(to && d > new Date(to)) return false;
  return true;
}

/* ============================= AUTH ============================= */
function renderLogin(){
  const body = document.getElementById('loginBody');
  body.innerHTML = `
    <div class="field"><label>${t('username')}</label><input id="loginUser" placeholder="admin" value="admin"></div>
    <div class="field"><label>${t('password')}</label><input id="loginPass" type="password" placeholder="••••" value="1234"></div>
    <div id="loginError"></div>
    <div class="login-actions">
      <button class="btn btn-copper btn-block" onclick="doLogin()">${t('login')}</button>
      <button class="linklike" onclick="renderForgot()">${t('forgot')}</button>
    </div>
    <p class="small muted" style="margin-top:16px;">Default: admin / 1234</p>
  `;
  document.getElementById('loginPass').addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin(); });
}
function renderForgot(){
  const body = document.getElementById('loginBody');
  body.innerHTML = `
    <p class="small muted">${LANG==='bn'?'পুনরুদ্ধার কোড লিখুন। এটি ব্যবসার মালিকের কাছে সংরক্ষিত একটি বিশেষ সংখ্যা।':'Enter the recovery code kept by the business owner to view all admin credentials.'}</p>
    <div class="field"><label>${t('recoveryCode')}</label><input id="recCode" placeholder="••••••"></div>
    <div id="loginError"></div>
    <div id="recResult"></div>
    <div class="login-actions">
      <button class="btn btn-copper btn-block" onclick="checkRecovery()">${LANG==='bn'?'যাচাই করুন':'Verify'}</button>
      <button class="linklike" onclick="renderLogin()">${t('back')}</button>
    </div>
  `;
}
function checkRecovery(){
  const code = document.getElementById('recCode').value.trim();
  const err = document.getElementById('loginError');
  if(code !== '504104'){ err.textContent = LANG==='bn'?'ভুল কোড।':'Incorrect code.'; return; }
  err.textContent='';
  const rows = SETTINGS.admins.map(a=>`<tr><td>${esc(a.username)}</td><td class="mono">${esc(a.password)}</td><td>${esc(a.role)}</td></tr>`).join('');
  document.getElementById('recResult').innerHTML = `
    <table style="margin-top:10px;"><thead><tr><th>${t('username')}</th><th>${t('password')}</th><th>Role</th></tr></thead>
    <tbody>${rows}</tbody></table>`;
}
function doLogin(){
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  const admin = SETTINGS.admins.find(a=>a.username===u && a.password===p);
  const err = document.getElementById('loginError');
  if(!admin){ err.textContent = LANG==='bn'?'ভুল ইউজারনেম বা পাসওয়ার্ড।':'Invalid username or password.'; return; }
  CURRENT_ADMIN = admin;
  document.getElementById('loginScreen').style.display='none';
  document.getElementById('app').style.display='block';
  boot();
}
function logout(){
  CURRENT_ADMIN = null;
  document.getElementById('app').style.display='none';
  document.getElementById('loginScreen').style.display='flex';
  renderLogin();
}

/* ============================= NAV / SHELL ============================= */
