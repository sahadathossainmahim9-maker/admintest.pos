function syncProductPrice(){
  const pid = document.getElementById('itProd').value;
  const p = findProduct(pid);
  if(p) { document.getElementById('itPrice').value = p.sellPrice; }
}
function toggleCustomerType(){
  const type = document.getElementById('csType').value;
  const div = document.getElementById('dealerPick');
  if(type === 'dealer'){
    div.style.display = 'block';
    div.innerHTML = `<label>Select Dealer Link</label><select id="dealerSelect" onchange="autofillDealerData()">
      <option value="">-- Choose --</option>
      ${DB.dealers.map(d=>`<option value="${d.id}">${esc(d.name)}</option>`).join('')}
    </select>`;
  } else {
    div.style.display = 'none';
    div.innerHTML = '';
  }
}
function autofillDealerData(){
  const did = document.getElementById('dealerSelect').value;
  const d = DB.dealers.find(x=>x.id===did);
  if(d){
    document.getElementById('csName').value = d.name;
    document.getElementById('csPhone').value = d.phone;
    document.getElementById('csAddress').value = d.address;
  }
}
function addToCart(){
  const pid = document.getElementById('itProd').value;
  const p = findProduct(pid);
  if(!p){ showToast('Select a valid product'); return; }
  const qty = Number(document.getElementById('itQty').value)||1;
  const price = Number(document.getElementById('itPrice').value) || p.sellPrice;
  cart.push({productId:pid, name:p.name+(p.model?' ('+p.model+')':''), qty, price});
  rerenderCartOnly();
}
function removeFromCart(i){ cart.splice(i,1); rerenderCartOnly(); }
function autofillCustomer(){
  const phone = document.getElementById('csPhone').value.trim();
  const c = findCustomerByPhone(phone);
  if(c){ document.getElementById('csName').value = c.name; document.getElementById('csAddress').value = c.address; }
}
function rerenderCartOnly(){
  const wrap = document.getElementById('cartTableWrap');
  if(!cart.length){
    if(wrap) wrap.innerHTML = `<div class="empty">${LANG==='bn'?'কার্ট খালি':'Cart is empty'}</div>`;
  } else {
    if(wrap) wrap.innerHTML = `<table class="items-table"><thead><tr><th>SL</th><th>Item Detail</th><th class="right">Qty</th><th class="right">Unit Price</th><th class="right">${t('total')}</th><th>Remove</th></tr></thead><tbody>
      ${cart.map((it,i)=>`<tr><td>${i+1}</td><td><b>${esc(it.name)}</b></td><td class="right">${it.qty}</td><td class="right mono">৳${money(it.price)}</td><td class="right mono">৳${money(it.qty*it.price)}</td>
      <td class="right"><button class="btn btn-danger btn-sm" onclick="removeFromCart(${i})">✕</button></td></tr>`).join('')}
    </tbody></table>`;
  }

  const status = document.getElementById('paymentStatus') ? document.getElementById('paymentStatus').value : 'full';
  if(document.getElementById('paidNowWrap')) document.getElementById('paidNowWrap').style.display = status==='partial' ? 'block':'none';
  if(document.getElementById('methodRow')) document.getElementById('methodRow').style.display = status==='due' ? 'none':'grid';

  const subtotal = cart.reduce((a,it)=>a+it.qty*it.price,0);
  const discount = Number(document.getElementById('csDiscount') ? document.getElementById('csDiscount').value : 0)||0;
  const total = Math.max(0, subtotal-discount);
  
  let paidNow = 0;
  if(status==='full') paidNow = total;
  else if(status==='partial') paidNow = Number(document.getElementById('paidNow') ? document.getElementById('paidNow').value : 0)||0;
  
  const due = Math.max(0, total-paidNow);
  const summary = document.getElementById('paySummary');
  if(summary){
    summary.innerHTML = `
      <div class="hr"></div>
      <table style="max-width:340px; margin-left:auto; font-size:14px;"><tbody>
      <tr><td>Gross Subtotal:</td><td class="right mono">৳ ${money(subtotal)}</td></tr>
      <tr><td>Special Discount:</td><td class="right mono">- ৳ ${money(discount)}</td></tr>
      <tr><td><b>Net Payable:</b></td><td class="right mono"><b>৳ ${money(total)}</b></td></tr>
      <tr><td>Paid Amount:</td><td class="right mono" style="color:var(--ok); font-weight:bold;">৳ ${money(paidNow)}</td></tr>
      <tr><td>Current Balance Due:</td><td class="right mono" style="color:${due>0?'var(--bad)':'var(--ok)'}; font-weight:bold;">৳ ${money(due)}</td></tr>
      </tbody></table>`;
  }
}
function finalizeSale(){
  if(!cart.length){ showToast(LANG==='bn'?'কার্টে পণ্য যোগ করুন':'Add items to cart first'); return; }
  const phone = document.getElementById('csPhone').value.trim();
  const name = document.getElementById('csName').value.trim() || "Walk-In Customer";
  const address = document.getElementById('csAddress').value.trim();
  const type = document.getElementById('csType').value;
  
  let dealerId = null;
  if(type==='dealer'){
    dealerId = document.getElementById('dealerSelect').value;
    if(!dealerId){ showToast('Link this transaction to a dealer account'); return; }
  }
  
  const subtotal = cart.reduce((a,it)=>a+it.qty*it.price,0);
  const discount = Number(document.getElementById('csDiscount').value)||0;
  const total = Math.max(0, subtotal-discount);
  const status = document.getElementById('paymentStatus').value;
  const method = document.getElementById('payMethod') ? document.getElementById('payMethod').value : 'cash';
  const ref = document.getElementById('payRef') ? document.getElementById('payRef').value.trim() : '';
  
  let paidNow = status==='full'? total : status==='partial'? (Number(document.getElementById('paidNow').value)||0) : 0;
  paidNow = Math.min(paidNow, total);
  const due = Math.max(0, total-paidNow);

  // stock deduction checks
  cart.forEach(it=>{ const p = findProduct(it.productId); if(p) p.stock = Math.max(0, Number(p.stock)-it.qty); });

  const invoiceNo = genInvoiceNo();
  const sale = {
    id:uid(), invoiceNo, date:nowISO(), customerName: name, customerPhone: phone,
    customerAddress: address, customerType:type, dealerId: dealerId,
    items: cart.map(it=>({...it})), subtotal, discount, total,
    payments: paidNow>0 ? [{date:nowISO(), amount:paidNow, method, ref}] : [],
    paidTotal: paidNow, dueAmount: due, status: due...0?'paid':(paidNow>0?'partial':'due')
  };
  
  DB.sales.push(sale);
  if(type==='dealer' && dealerId){
    const dl = DB.dealers.find(d=>d.id===dealerId);
    if(dl){
      dl.dueBalance = (dl.dueBalance||0) + due;
      dl.transactions = dl.transactions || [];
      dl.transactions.push({date:nowISO(), type:'sale', amount:total, note:'Invoice '+invoiceNo});
    }
  } else if(phone) {
    const c = upsertCustomer(name, phone, address);
    if(c) c.dueBalance = (c.dueBalance||0) + due;
  }
  
  saveCore();
  cart = [];
  showToast(LANG==='bn'?'ইনভয়েস সংরক্ষিত হয়েছে: ':'Invoice recorded safely: '+invoiceNo);
  showInvoicePreview(sale.id);
}

