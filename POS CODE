/* ============================= MODAL WINDOW ENGINE ============================= */
function openModal(title, bodyHtml, onSave, wide){
  closeModal();
  const bg = document.createElement('div');
  bg.className='modal-bg'; bg.id='activeModal';
  bg.innerHTML = `<div class="modal" style="${wide?'width:680px;':''}">
    <button class="close-x" onclick="closeModal()">✕</button>
    <h3>${title}</h3>
    <div id="modalBody">${bodyHtml}</div>
    ${onSave? `<div class="pill-row" style="margin-top:16px;"><button class="btn btn-copper" id="modalSaveBtn">${t('save')}</button><button class="btn btn-ghost" onclick="closeModal()">${t('cancel')}</button></div>` : ''}
  </div>`;
  document.body.appendChild(bg);
  if(onSave) document.getElementById('modalSaveBtn').onclick = onSave;
}
function closeModal(){ const m = document.getElementById('activeModal'); if(m) m.remove(); }

